// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "./prisma-client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

generator zod {
  provider = "zod-prisma-types"
}

model Event {
  id                      String            @id @default(uuid())
  year                    Int               @db.Year
  registration_start_date DateTime
  registration_end_date   DateTime          @default(now())
  note                    String?           @db.Text
  vessel_types            EventVesselType[]
  registrations           Registration[]
  is_active               Boolean           @default(true)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime?         @updatedAt
}

model Participant {
  id              String       @id @default(uuid())
  first_name      String
  last_name       String
  date_of_birth   DateTime
  registration    Registration @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  registration_id String
}

model Registrant {
  id             String         @id @default(uuid())
  first_name     String
  last_name      String
  email          String
  date_of_birth  DateTime
  postal_code    String
  street_name    String
  street_number  String
  city           String
  place_of_birth String
  registration   Registration[]
}

model Registration {
  id                      String        @id @default(uuid())
  music_request           String?
  registrant              Registrant    @relation(fields: [registrant_id], references: [id], onDelete: Cascade)
  registrant_id           String
  participants            Participant[]
  vessel                  Vessel        @relation(fields: [vessel_id], references: [id], onDelete: Cascade)
  vessel_id               String
  assosciation            String?
  event                   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId                 String
  createdAt               DateTime      @default(now())
  sent_confirmation_email Boolean       @default(false)
  has_paid                Boolean       @default(false)
  updatedAt               DateTime?     @updatedAt
}

model VesselType {
  id              String            @id @default(uuid())
  max_registrants Int               @default(2)
  type            String
  vessels         Vessel[]
  events          EventVesselType[]
  is_active       Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?         @updatedAt
}

model EventVesselType {
  id               String     @id @default(uuid())
  event            Event      @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_id         String
  vessel_type      VesselType @relation(fields: [vessel_type_id], references: [id], onDelete: Cascade)
  vessel_type_id   String
  max_participants Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime?  @updatedAt

  @@unique([event_id, vessel_type_id])
  @@index([event_id])
  @@index([vessel_type_id])
}

model Vessel {
  id             String         @id @default(uuid())
  name           String
  type           VesselType     @relation(fields: [vessel_type_id], references: [id])
  vessel_type_id String
  registration   Registration[]
}

model User {
  id            String    @id
  session       Session[]
  email         String    @unique
  password_hash String
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)
}
